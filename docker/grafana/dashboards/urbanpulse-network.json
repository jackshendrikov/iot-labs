{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "liveNow": false,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP latency p50 / p95 / p99 (ms)",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 9 },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(store_api_http_request_latency_seconds_bucket[1m]))) * 1000", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(store_api_http_request_latency_seconds_bucket[1m]))) * 1000", "legendFormat": "p95", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(store_api_http_request_latency_seconds_bucket[1m]))) * 1000", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "type": "timeseries",
      "title": "Throughput (req/s) за endpoint",
      "id": 2,
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 9 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (path) (rate(store_api_http_requests_total[1m]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "type": "timeseries",
      "title": "Error rate (4xx/5xx частка)",
      "id": 3,
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 9 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(store_api_http_requests_total{status=~\"4..|5..\"}[1m])) / clamp_min(sum(rate(store_api_http_requests_total[1m])), 1)",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 4 } }
    },
    {
      "type": "stat",
      "title": "Network anomalies за 1 годину",
      "id": 4,
      "gridPos": { "x": 0, "y": 18, "w": 6, "h": 5 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(urbanpulse_network_anomalies_total[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "type": "bargauge",
      "title": "Network anomalies по метриці/severity",
      "id": 5,
      "gridPos": { "x": 6, "y": 18, "w": 18, "h": 5 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (metric, severity) (urbanpulse_network_anomalies_total)",
          "legendFormat": "{{metric}} · {{severity}}",
          "refId": "A"
        }
      ],
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "type": "table",
      "title": "Останні події (з PostgreSQL)",
      "id": 6,
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 10 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT timestamp, metric, severity, value, baseline_mean, baseline_std, zscore FROM network_anomalies ORDER BY timestamp DESC LIMIT 100",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["urbanpulse", "network"],
  "time": { "from": "now-30m", "to": "now" },
  "title": "UrbanPulse — Network Health",
  "uid": "urbanpulse-network",
  "version": 1
}
